{
  "name": "generic-filehandle2",
  "description": "uniform interface for accessing binary data from local files, remote HTTP resources, and browser Blob data",
  "version": "2.1.4",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "import": "./esm/browser.js",
        "require": "./dist/browser.js"
      },
      "import": "./esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/generic-filehandle2.git"
  },
  "license": "MIT",
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com",
    "url": "https://github.com/cmdcolin"
  },
  "engines": {
    "node": ">=14"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "test": "vitest",
    "coverage": "yarn test --coverage",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "clean": "rimraf dist esm",
    "format": "prettier --write .",
    "prebuild": "yarn clean",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "build": "yarn build:esm && yarn build:es5",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "yarn lint && yarn test --run && yarn build",
    "postversion": "git push --follow-tags"
  },
  "keywords": [
    "bionode",
    "biojs",
    "ucsc",
    "genomics"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/range-parser": "^1.2.7",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "range-parser": "^1.2.1",
    "rimraf": "^6.1.3",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
